{
  "name": "peptidai",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "sync:ios": "npm run build && npx cap sync ios",
    "ota:compat": "npx @capgo/cli@latest bundle compatibility com.peptidai.app --channel production",
    "ota:upload": "npm run build && npx @capgo/cli@latest bundle upload com.peptidai.app --path dist --channel production --bundle 1.0.0-ota.$(date +%Y%m%d%H%M%S).$(git rev-parse --short HEAD) --comment $(git rev-parse --short HEAD)",
    "ota:upload:beta": "npm run build && npx @capgo/cli@latest bundle upload com.peptidai.app --path dist --channel beta --bundle 1.0.0-beta.$(date +%Y%m%d%H%M%S).$(git rev-parse --short HEAD) --comment $(git rev-parse --short HEAD)"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/keyboard": "^8.0.3",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@capawesome/capacitor-app-review": "^8.0.1",
    "@capgo/capacitor-health": "^8.6.0",
    "@capgo/capacitor-updater": "^8.50.2",
    "@google/genai": "^2.8.0",
    "@revenuecat/purchases-capacitor": "^13.1.2",
    "firebase": "^12.13.0",
    "html-to-image": "^1.11.13",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.15.1",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/configure": "^2.0.10",
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12"
  }
}
